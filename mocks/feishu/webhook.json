{
  "request": {
    "method": "POST",
    "urlPath": "/mocks/feishu/webhook"
  },
  "response": {
    "status": 200,
    "headers": { "Content-Type": "application/json;charset=UTF-8" },
    "jsonBody": {
      "code": 0,
      "msg": "success",
      "type": "feishu_bot",
      "received_at": "{{now format='yyyy-MM-dd HH:mm:ss'}}",
      "message_id": "FS-{{randomValue length=12 type='ALPHANUMERIC'}}"
    },
    "transformers": ["response-template"]
  }
}
